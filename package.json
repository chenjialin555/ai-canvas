{
  "name": "ai-canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:api\"",
    "dev:client": "vite",
    "dev:api": "sh -c 'set -a; [ -f .env ] && . ./.env; set +a; exec uv run uvicorn backend.app.main:app --host 0.0.0.0 --port ${API_PORT:-13555} --reload'",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "konva": "^9.3.18",
    "nanoid": "^5.0.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.10.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.1"
  }
}
