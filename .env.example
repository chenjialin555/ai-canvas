# 复制为 .env 后填写；勿提交 Git。若密钥曾出现在聊天/截图，请先在各平台「轮换」再使用新值。

# =========================
# Comfly 统一网关
# =========================
COMFLY_BASE_URL=https://ai.comfly.chat

# =========================
# 模型 API Key
# =========================
QWEN_API_KEY=
BANANA_API_KEY=
FLUX_API_KEY=
DOUBAO_API_KEY=

GEMINI_API_KEY=
GEMINI_BASE_URL=https://ai.comfly.chat

KSYUN_API_KEY=
KSYUN_BASE_URL=https://kspmas.ksyun.com

# =========================
# 阿里云 OSS（任填一种桶名即可：OSS_BUCKET 或 OSS_BUCKET_NAME）
# 对象前缀：OSS_OBJECT_PREFIX 或 OSS_PATH（二选一，同时设时以 OSS_OBJECT_PREFIX 为准）
# 公网访问建议 OSS_PUBLIC_BASE_URL 使用 https
# =========================
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=cn-guangzhou
OSS_ENDPOINT=http://object.intuly.com
OSS_USE_CNAME=true

OSS_BUCKET=
OSS_BUCKET_NAME=

OSS_PUBLIC_BASE_URL=https://object.intuly.com

OSS_OBJECT_PREFIX=ai/img/build
# OSS_PATH=ai/img/build

# =========================
# FastAPI（本地 uvicorn；默认 13555，避免与占用 8000 的进程冲突）
# 修改端口时请同步改 API_PORT，Vite 会读 .env 代理到同一端口
# =========================
API_HOST=0.0.0.0
API_PORT=13555
RETURN_RAW_RESPONSE=false

# 后端日志：默认写入项目根目录 logs/backend.log（相对路径相对于进程 cwd）
# LOG_DIR=logs
# LOG_LEVEL=INFO
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5
